# 本地 pnpm dev：API 走 Vite 代理，VITE_API_BASE_URL 保持为空
VITE_APP_ENV=dev
VITE_API_PROXY_TARGET=http://127.0.0.1:8061/

# 浏览器请求 /api/... 会代理到 VITE_API_PROXY_TARGET
VITE_API_BASE_URL=

# --- 以下为 Jenkins / CI 打包用（勿用于 pnpm dev）---
# dev  静态包：pnpm run build:dev  → 读取 .env.dev
# test 静态包：pnpm run build:test → 读取 .env.test
# prod 静态包：pnpm run build:prod → 读取 .env.production
#
# 或在 Jenkins 中覆盖（无需改文件）：
#   VITE_API_BASE_URL=http://dev-api.monihr.com pnpm run build:dev
#
# 代码读取：src/lib/apiClient.ts → import.meta.env.VITE_API_BASE_URL
